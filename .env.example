# ============================================================
# Google API Credentials
# ============================================================
# Path to your Google OAuth2 credentials JSON file
# Download from: https://console.cloud.google.com/apis/credentials
GOOGLE_CREDENTIALS_PATH=credentials.json

# Google Calendar API OAuth2 token (generated on first auth)
GOOGLE_TOKEN_PATH=token.json

# Google Maps Platform API Key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================================
# Gemini / Vertex AI
# ============================================================
# Gemini API key (from https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your-gemini-api-key

# OR use Vertex AI (set project + location instead of API key)
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_GENAI_USE_VERTEXAI=true

# ============================================================
# AlloyDB Connection
# ============================================================
# AlloyDB instance connection name (project:region:cluster:instance)
ALLOYDB_INSTANCE_URI=projects/YOUR_PROJECT/locations/YOUR_REGION/clusters/YOUR_CLUSTER/instances/YOUR_INSTANCE

# AlloyDB database credentials
ALLOYDB_DB_NAME=agentic_ai
ALLOYDB_DB_USER=postgres
ALLOYDB_DB_PASSWORD=your-alloydb-password

# Optional: direct connection URL (overrides the above if set)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ============================================================
# Application settings
# ============================================================
LOG_LEVEL=INFO

# Default Gemini model to use
GEMINI_MODEL=gemini-2.0-flash
